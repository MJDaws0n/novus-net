module net_tests_windows_x86;

import main;

fn test_pass(name: str) -> void {
    print_raw("  [PASS] " + name + "\n");
}

fn test_fail(name: str, detail: str) -> void {
    print_raw("  [FAIL] " + name + ": " + detail + "\n");
}

fn assert_eq_i32(name: str, got: i32, expected: i32) -> i32 {
    if (got == expected) { test_pass(name); return 0; }
    test_fail(name, "got " + i32_to_str(got) + ", expected " + i32_to_str(expected));
    return 1;
}

fn assert_eq_i64(name: str, got: i64, expected: i64) -> i32 {
    if (got == expected) { test_pass(name); return 0; }
    test_fail(name, "got " + i64_to_str(got) + ", expected " + i64_to_str(expected));
    return 1;
}

fn assert_eq_str(name: str, got: str, expected: str) -> i32 {
    if (str_equals(got, expected)) { test_pass(name); return 0; }
    test_fail(name, "got '" + got + "', expected '" + expected + "'");
    return 1;
}

fn assert_true(name: str, val: bool) -> i32 {
    if (val) { test_pass(name); return 0; }
    test_fail(name, "expected true");
    return 1;
}

fn assert_gt_i32(name: str, val: i32, threshold: i32) -> i32 {
    if (val > threshold) { test_pass(name); return 0; }
    test_fail(name, "expected > " + i32_to_str(threshold));
    return 1;
}

fn assert_gt_i64(name: str, val: i64, threshold: i64) -> i32 {
    if (val > threshold) { test_pass(name); return 0; }
    test_fail(name, "expected > " + i64_to_str(threshold));
    return 1;
}

fn assert_gte_i32(name: str, val: i32, threshold: i32) -> i32 {
    if (val >= threshold) { test_pass(name); return 0; }
    test_fail(name, "expected >= " + i32_to_str(threshold) + ", got " + i32_to_str(val));
    return 1;
}

fn assert_neq_u64(name: str, val: u64, not_val: u64) -> i32 {
    if (val != not_val) { test_pass(name); return 0; }
    test_fail(name, "expected != given value");
    return 1;
}

fn main(argc: i32, argv: u64) -> i32 {
    let fails: i32 = 0;
    print_raw("=== net tests (windows_x86) ===\n");

    // ── Socket creation (assembly: syscall socket) ──
    print_raw("\n--- Socket ---\n");
    let fd: i32 = net_socket();
    fails = fails + assert_true("net_socket >= 0", fd >= 0);

    if (fd >= 0) {
        // ── Socket options (assembly: syscall setsockopt/fcntl) ──
        print_raw("\n--- Socket Options ---\n");
        let r1: i32 = net_set_reuse(fd);
        fails = fails + assert_eq_i32("net_set_reuse", r1, 0);
        let r2: i32 = net_set_keepalive(fd);
        fails = fails + assert_eq_i32("net_set_keepalive", r2, 0);
        let r3: i32 = net_set_nonblock(fd);
        fails = fails + assert_gte_i32("net_set_nonblock", r3, 0);

        // ── Bind / Listen (assembly: syscall bind/listen) ──
        print_raw("\n--- Bind / Listen ---\n");
        let br: i32 = net_bind(fd, 39876);
        fails = fails + assert_eq_i32("net_bind", br, 0);
        if (br == 0) {
            let listen_r: i32 = net_listen(fd, 5);
            fails = fails + assert_eq_i32("net_listen", listen_r, 0);
        }

        // ── Close (assembly: syscall close) ──
        net_close(fd);
        print_raw("  [PASS] net_close\n");
    }

    // ── Loopback test (assembly: connect/accept/read/write) ──
    print_raw("\n--- Loopback ---\n");
    let port: i32 = 39877;
    let srv: i32 = net_socket();
    if (srv < 0) {
        test_fail("loopback: server socket", "fd < 0");
        fails = fails + 1;
    }
    if (srv >= 0) {
        net_set_reuse(srv);
        let b2: i32 = net_bind(srv, port);
        if (b2 != 0) {
            test_fail("loopback: bind", "failed");
            fails = fails + 1;
            net_close(srv);
        }
        if (b2 == 0) {
            net_listen(srv, 5);
            let cli: i32 = net_socket();
            let cr: i32 = net_connect(cli, 127, 0, 0, 1, port);
            if (cr != 0) {
                test_fail("loopback: connect", "failed");
                fails = fails + 1;
            }
            if (cr == 0) {
                let acc: i32 = net_accept(srv);
                if (acc < 0) {
                    test_fail("loopback: accept", "fd < 0");
                    fails = fails + 1;
                }
                if (acc >= 0) {
                    let msg: str = "hello";
                    let wr: i32 = net_write(cli, msg, 5);
                    fails = fails + assert_eq_i32("loopback: write", wr, 5);
                    let rbuf: str = make_buffer(16);
                    let nr: i32 = net_read(acc, rbuf, 16);
                    fails = fails + assert_eq_i32("loopback: read len", nr, 5);
                    if (nr >= 5) {
                        fails = fails + assert_eq_i32("loopback: byte h", byte_at(rbuf, 0), 104);
                        fails = fails + assert_eq_i32("loopback: byte e", byte_at(rbuf, 1), 101);
                        fails = fails + assert_eq_i32("loopback: byte l", byte_at(rbuf, 2), 108);
                        fails = fails + assert_eq_i32("loopback: byte l2", byte_at(rbuf, 3), 108);
                        fails = fails + assert_eq_i32("loopback: byte o", byte_at(rbuf, 4), 111);
                    }
                    net_close(acc);
                }
            }
            net_close(cli);
            net_close(srv);
        }
    }

    // ── Signal (assembly: syscall sigaction) ──
    print_raw("\n--- Signal ---\n");
    net_ignore_sigpipe();
    print_raw("  [PASS] net_ignore_sigpipe (no crash)\n");

    // ── net_listen_on (high-level) ──
    print_raw("\n--- High-level ---\n");
    let hl_fd: i32 = net_listen_on(39878, 5);
    if (hl_fd >= 0) {
        test_pass("net_listen_on");
        net_close(hl_fd);
    } else {
        test_fail("net_listen_on", "fd < 0");
        fails = fails + 1;
    }

    // ── Summary ──
    print_raw("\n");
    if (fails > 0) {
        print_raw(i32_to_str(fails) + " test(s) FAILED\n");
        return 1;
    }
    print_raw("All tests PASSED\n");
    return 0;
}
